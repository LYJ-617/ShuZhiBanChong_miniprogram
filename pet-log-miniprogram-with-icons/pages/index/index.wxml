<view class="container">
  <view class="reminder-section">
    <view class="reminder-title">日程提醒</view>
    <view class="reminder-list">
      <view wx:for="{{reminders}}" wx:key="id" class="reminder-item">
        <text class="reminder-text">{{item.content}}</text>
        <text class="reminder-time">{{item.time}}</text>
      </view>
    </view>
  </view>
  <view class="function-section">
    <view class="function-title">功能入口</view>
    <view class="function-grid">
      <view class="function-item" bindtap="goToLog">
        <view class="function-icon log-icon"></view>
        <text class="function-text">养宠日志</text>
        <text class="log-tip" wx:if="{{hasUnrecorded}}">今天还没有记录毛孩子的状态哦~</text>
      </view>
      <view class="function-item" bindtap="goToCommunity">
        <view class="function-icon community-icon"></view>
        <text class="function-text">社区</text>
      </view>
      <view class="function-item" bindtap="goToService">
        <view class="function-icon service-icon"></view>
        <text class="function-text">服务</text>
      </view>
      <view class="function-item" bindtap="goToMine">
        <view class="function-icon mine-icon"></view>
        <text class="function-text">我的</text>
      </view>
      <view class="function-item" bindtap="goToAiReport">
        <view class="function-icon report-icon"></view>
        <text class="function-text">AI分析报告</text>
      </view>
    </view>
  </view>
</view>