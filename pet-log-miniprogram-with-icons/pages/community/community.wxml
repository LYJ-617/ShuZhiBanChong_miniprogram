<view class="container">
  <view class="header">
    <button class="publish-btn" bindtap="showPublishModal">发布帖子</button>
  </view>
  <view class="tag-filter">
    <view class="tag-list">
      <view class="tag {{selectedTag === '' ? 'active' : ''}}" bindtap="selectTag" data-tag="">全部</view>
      <view class="tag {{selectedTag === '日常记录' ? 'active' : ''}}" bindtap="selectTag" data-tag="日常记录">日常记录</view>
      <view class="tag {{selectedTag === '医疗知识' ? 'active' : ''}}" bindtap="selectTag" data-tag="医疗知识">医疗知识</view>
      <view class="tag {{selectedTag === '好物分享' ? 'active' : ''}}" bindtap="selectTag" data-tag="好物分享">好物分享</view>
      <view class="tag {{selectedTag === '科普知识' ? 'active' : ''}}" bindtap="selectTag" data-tag="科普知识">科普知识</view>
    </view>
  </view>
  <view class="post-list">
    <view wx:for="{{postList}}" wx:key="id" class="post-item" bindtap="goToPostDetail" data-post-id="{{item.id}}">
      <view class="post-header">
        <text class="username">{{item.username}}</text>
        <text class="post-time">{{formatTime(item.createTime)}}</text>
      </view>
      <view class="post-content">{{item.content}}</view>
      <view class="post-tags">
        <view class="tag" wx:for="{{item.tags}}" wx:key="*this">#{{item}}</view>
      </view>
      <view class="post-actions">
        <view class="action-item" bindtap="likePost" data-post-id="{{item.id}}">
          <text class="icon">👍</text>
          <text>{{item.likeCount}}</text>
        </view>
        <view class="action-item" bindtap="commentPost" data-post-id="{{item.id}}">
          <text class="icon">💬</text>
          <text>{{item.commentCount}}</text>
        </view>
        <view class="action-item" bindtap="collectPost" data-post-id="{{item.id}}">
          <text class="icon">⭐</text>
          <text>{{item.collectCount}}</text>
        </view>
      </view>
    </view>
  </view>
  <view wx:if="{{postList.length === 0}}" class="empty-tip">
    <text>还没有帖子哦，快去发布吧~</text>
  </view>
</view>

<modal title="发布社区帖子" hidden="{{!publishModalVisible}}" confirm-text="发布" cancel-text="取消" bindconfirm="submitPost" bindcancel="hidePublishModal">
  <community-publish bind:postData="onPostDataChange" />
</modal>