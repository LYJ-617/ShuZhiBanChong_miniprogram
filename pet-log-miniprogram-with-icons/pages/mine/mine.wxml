<view class="container">
  <view class="user-info">
    <view class="avatar">
      <text>👤</text>
    </view>
    <view class="user-detail">
      <text class="username">{{userInfo?.username || '未登录'}}</text>
      <text class="desc">养宠达人</text>
    </view>
  </view>
  <view class="pet-info">
    <view class="section-title">我的宠物</view>
    <view class="pet-list">
      <view wx:for="{{petList}}" wx:key="id" class="pet-item">
        <text class="pet-name">{{item.petName}}</text>
        <text class="pet-type">{{item.type}} - {{item.breed}}</text>
      </view>
    </view>
  </view>
  <view class="menu-list">
    <view class="menu-item" bindtap="goToSetting">
      <text class="menu-text">设置</text>
      <text class="arrow">→</text>
    </view>
    <view class="menu-item" bindtap="logout">
      <text class="menu-text">退出登录</text>
      <text class="arrow">→</text>
    </view>
  </view>
</view>