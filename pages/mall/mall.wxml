<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索商品" bindinput="onSearchInput" value="{{searchKeyword}}" />
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view class="category-item {{selectedCategory === '' ? 'active' : ''}}" catchtap="selectCategory" data-category="">
        全部
      </view>
      <view class="category-item {{selectedCategory === '食品' ? 'active' : ''}}" catchtap="selectCategory" data-category="食品">
        食品
      </view>
      <view class="category-item {{selectedCategory === '用品' ? 'active' : ''}}" catchtap="selectCategory" data-category="用品">
        用品
      </view>
      <view class="category-item {{selectedCategory === '玩具' ? 'active' : ''}}" catchtap="selectCategory" data-category="玩具">
        玩具
      </view>
      <view class="category-item {{selectedCategory === '医疗' ? 'active' : ''}}" catchtap="selectCategory" data-category="医疗">
        医疗
      </view>
      <view class="category-item {{selectedCategory === '服饰' ? 'active' : ''}}" catchtap="selectCategory" data-category="服饰">
        服饰
      </view>
    </view>
  </scroll-view>

  <!-- 排序和筛选 -->
  <view class="sort-bar">
    <view class="sort-item {{sortType === 'default' ? 'active' : ''}}" catchtap="setSortType" data-type="default">综合</view>
    <view class="sort-item {{sortType === 'sales' ? 'active' : ''}}" catchtap="setSortType" data-type="sales">销量</view>
    <view class="sort-item {{sortType === 'price' ? 'active' : ''}}" catchtap="setSortType" data-type="price">
      价格
      <text class="sort-arrow {{priceOrder === 'asc' ? 'asc' : 'desc'}}"></text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-list">
    <view wx:for="{{filteredProducts}}" wx:key="id" class="product-item" catchtap="goToProductDetail" data-product="{{item}}">
      <view class="product-image">
        <image src="{{item.image}}" mode="aspectFill" class="product-img" />
        <view wx:if="{{item.tag}}" class="product-tag">{{item.tag}}</view>
      </view>
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-desc">{{item.description}}</view>
        <view class="product-meta">
          <text class="product-sales">已售{{item.sales}}</text>
          <text class="product-rating">⭐ {{item.rating}}</text>
        </view>
        <view class="product-footer">
          <view class="product-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.price}}</text>
            <text wx:if="{{item.originalPrice}}" class="original-price">¥{{item.originalPrice}}</text>
          </view>
          <button class="add-cart-btn" catchtap="addToCart" data-product="{{item}}" hover-class="btn-hover">
            <text class="cart-icon">🛒</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{filteredProducts.length === 0}}" class="empty-state">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无相关商品</text>
  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar" wx:if="{{cartCount > 0}}">
    <view class="cart-info" catchtap="goToCart">
      <view class="cart-icon-wrapper">
        <text class="cart-bar-icon">🛒</text>
        <text class="cart-count">{{cartCount}}</text>
      </view>
      <text class="cart-total">¥{{cartTotal}}</text>
    </view>
    <button class="checkout-btn" catchtap="checkout">去结算</button>
  </view>
</view>
