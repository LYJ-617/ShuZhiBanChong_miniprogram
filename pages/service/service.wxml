<view class="container" style="padding-top: {{statusBarTop + 20}}rpx; padding-bottom: {{safeBottom + 140}}rpx;">
  <view class="top-tabs">
    <view class="top-tab {{activeModule==='mall'?'active':''}}" data-module="mall" bindtap="switchModule">商城</view>
    <view class="top-tab {{activeModule==='consult'?'active':''}}" data-module="consult" bindtap="switchModule">线上问诊</view>
    <view class="top-tab {{activeModule==='reserve'?'active':''}}" data-module="reserve" bindtap="switchModule">服务预约</view>
  </view>

  <view class="search-row">
    <input class="search-input" placeholder="搜索" bindinput="onSearchInput" value="{{keyword}}" />
  </view>

  <view wx:if="{{activeModule==='mall'}}">
    <view class="filter-row">
      <view wx:for="{{mallCats}}" wx:key="*this" class="chip {{mallCat===item?'active':''}}" bindtap="selectMallCat" data-cat="{{item}}">{{item}}</view>
    </view>
    <view class="grid two-col">
      <view wx:for="{{mallList}}" wx:key="id" class="card" bindtap="goToMall">
        <view class="card-title">{{item.name}}</view>
        <view class="card-sub">{{item.desc}}</view>
        <view class="card-meta">￥{{item.price}}</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeModule==='consult'}}">
    <view class="filter-row">
      <view wx:for="{{consultPetTypes}}" wx:key="*this" class="chip {{consultPetType===item?'active':''}}" bindtap="selectConsultPetType" data-type="{{item}}">{{item}}</view>
    </view>
    <view class="list">
      <view wx:for="{{doctorList}}" wx:key="id" class="list-card" bindtap="goToConsult">
        <view class="row"><text>{{item.name}} · {{item.title}}</text><text>￥{{item.price}}/次</text></view>
        <view class="row sub"><text>擅长：{{item.goodAt}}</text><text>{{item.count}}问诊 | {{item.score}}分</text></view>
      </view>
    </view>
  </view>

  <view wx:else>
    <view class="filter-row">
      <view wx:for="{{reserveCats}}" wx:key="*this" class="chip {{reserveCat===item?'active':''}}" bindtap="selectReserveCat" data-cat="{{item}}">{{item}}</view>
    </view>
    <view class="grid two-col">
      <view wx:for="{{reserveList}}" wx:key="id" class="card" bindtap="startReserveFlow" data-id="{{item.id}}">
        <view class="card-title">{{item.name}}</view>
        <view class="card-sub">{{item.store}} · {{item.distance}}</view>
        <view class="card-meta">￥{{item.price}} · {{item.count}}人预约</view>
      </view>
    </view>
  </view>
</view>