<view class="container">
  <view class="pet-selector">
    <view class="tag-list">
      <view wx:for="{{petList}}" wx:key="id" class="tag {{selectedPetId === item.id ? 'active' : ''}}" bindtap="selectPet" data-pet-id="{{item.id}}">{{item.petName}}</view>
    </view>
  </view>

  <view class="service-grid">
    <view class="service-item" bindtap="goToMall">
      <view class="service-icon mall-icon"></view>
      <text class="service-text">商城</text>
    </view>
    <view class="service-item" bindtap="goToConsult">
      <view class="service-icon consult-icon"></view>
      <text class="service-text">线上问诊</text>
    </view>
    <view class="service-item" bindtap="goToReservation">
      <view class="service-icon reservation-icon"></view>
      <text class="service-text">服务预约</text>
    </view>
  </view>

  <view class="recommendation-section" wx:if="{{recommendProducts.length > 0}}">
    <view class="section-title">为您推荐</view>
    <view class="product-list">
      <view wx:for="{{recommendProducts}}" wx:key="id" class="product-item">
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-reason">{{item.reason}}</view>
        </view>
        <view class="product-right">
          <view class="product-price">¥{{item.price}}</view>
          <button class="buy-btn" bindtap="buyProduct" data-id="{{item.id}}">购买</button>
        </view>
      </view>
    </view>
  </view>

  <view class="recommendation-section" wx:if="{{recommendDoctors.length > 0}}">
    <view class="section-title">推荐专家</view>
    <view class="doctor-list">
      <view wx:for="{{recommendDoctors}}" wx:key="id" class="doctor-item">
        <view class="doctor-info">
          <view class="doctor-name">{{item.name}}</view>
          <view class="doctor-specialty">擅长：{{item.specialty}}</view>
        </view>
        <button class="consult-btn" bindtap="goToConsult">问诊</button>
      </view>
    </view>
  </view>

  <view class="recommendation-section" wx:if="{{recommendHospitals.length > 0}}">
    <view class="section-title">推荐医院</view>
    <view class="hospital-list">
      <view wx:for="{{recommendHospitals}}" wx:key="id" class="hospital-item">
        <view class="hospital-info">
          <view class="hospital-name">{{item.name}}</view>
          <view class="hospital-distance">{{item.distance}}</view>
        </view>
        <button class="reserve-btn" bindtap="goToReservation">预约</button>
      </view>
    </view>
  </view>
</view>