<view class="order-list-page">
  <!-- 状态标签 -->
  <view class="tabs">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
    <view class="tab-item {{activeTab === 'pending_payment' ? 'active' : ''}}" data-tab="pending_payment" bindtap="switchTab">待付款</view>
    <view class="tab-item {{activeTab === 'pending_ship' ? 'active' : ''}}" data-tab="pending_ship" bindtap="switchTab">待发货</view>
    <view class="tab-item {{activeTab === 'pending_receipt' ? 'active' : ''}}" data-tab="pending_receipt" bindtap="switchTab">待收货</view>
    <view class="tab-item {{activeTab === 'completed' ? 'active' : ''}}" data-tab="completed" bindtap="switchTab">已完成</view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-item" wx:for="{{orderList}}" wx:key="id" data-id="{{item.id}}" bindtap="goToDetail">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status">{{item.statusText}}</text>
      </view>
      <view class="order-content">
        <view class="product-info">
          <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill"></image>
          <text wx:else>📦</text>
          <view class="product-detail">
            <text class="product-name">{{item.productName}}</text>
            <text class="product-price">¥{{item.price}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{orderList.length === 0}}">
    <text class="empty-icon">🛍️</text>
    <text class="empty-text">暂无订单记录</text>
    <view class="empty-btn" bindtap="goToMall">去逛逛</view>
  </view>
</view>