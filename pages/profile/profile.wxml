<view class="container">
  <view class="profile-header">
    <view class="avatar-section" bindtap="chooseAvatar">
      <image wx:if="{{userInfo && userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-image"></image>
      <view wx:else class="avatar-placeholder">👤</view>
      <text class="avatar-tip">点击更换头像</text>
    </view>
    <view class="info-section">
      <view class="info-row" bindtap="editUsername">
        <text class="info-label">用户名</text>
        <text class="info-value">{{userInfo && userInfo.username || '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="info-row" bindtap="editPhone">
        <text class="info-label">手机号</text>
        <text class="info-value">{{userInfo && userInfo.phone || '未绑定'}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="info-row" bindtap="editWechatId">
        <text class="info-label">微信号</text>
        <text class="info-value">{{userInfo && userInfo.wechatId || '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="info-row more-row" bindtap="goToMoreInfo">
        <text class="info-label">更多</text>
        <view class="more-preview">
          <text wx:if="{{userInfo && userInfo.gender}}" class="preview-item">{{userInfo.gender}}</text>
          <text wx:if="{{userInfo && userInfo.region}}" class="preview-item">{{userInfo.region}}</text>
          <text wx:if="{{userInfo && userInfo.signature}}" class="preview-item">{{userInfo.signature}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="address-section">
    <view class="section-title">我的地址</view>
    <view class="address-list">
      <view wx:for="{{addressList}}" wx:key="id" class="address-item" bindtap="editAddress" data-index="{{index}}">
        <view class="address-main">
          <text class="address-name">{{item.name}} {{item.phone}}</text>
          <text class="address-detail">{{item.province}} {{item.city}} {{item.district}} {{item.detail}}</text>
          <text wx:if="{{item.isDefault}}" class="default-tag">默认</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view wx:if="{{addressList.length === 0}}" class="empty-address">
        <text class="empty-text">暂无地址</text>
      </view>
    </view>
    <view class="add-address-btn" bindtap="addAddress">
      <text class="add-text">+ 添加新地址</text>
    </view>
  </view>
</view>
