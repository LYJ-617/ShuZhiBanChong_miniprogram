<view class="container">
  <!-- 顶部 Logo 和标题 -->
  <view class="header">
    <view class="logo-wrapper">
      <image class="logo" src="../../../static/images/logo.png" mode="aspectFit" />
    </view>
    <view class="title-wrapper">
      <text class="title">你好！欢迎登录阿间宠物</text>
    </view>
  </view>

  <!-- 协议复选框 -->
  <view class="agreement-section">
    <view class="checkbox-wrapper" catchtap="toggleAgreement">
      <view class="checkbox {{isAgreed ? 'checked' : ''}}">
        <text wx:if="{{isAgreed}}" class="check-icon">✓</text>
      </view>
      <text class="agreement-text">
        我已阅读并同意《阿间宠物隐私政策》和《阿间宠物用户协议》
      </text>
    </view>
  </view>

  <!-- 登录按钮 -->
  <view class="button-section">
    <button
      class="login-btn {{isAgreed ? 'active' : 'disabled'}}"
      open-type="getPhoneNumber"
      bindgetphonenumber="handleGetPhoneNumber"
      disabled="{{!isAgreed}}"
    >
      手机号快捷登录
    </button>
  </view>
</view>