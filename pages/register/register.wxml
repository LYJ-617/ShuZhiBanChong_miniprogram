<view class="register-container">
  <view class="form-item">
    <text class="label">宠物大类</text>
    <picker mode="selector" range="{{categoryList}}" bindchange="onCategoryChange" value="{{categoryIndex}}">
      <view class="picker-text">{{categoryList[categoryIndex] || '请选择宠物大类'}}</view>
    </picker>
  </view>

  <view class="form-item">
    <text class="label">宠物小类</text>
    <picker mode="selector" range="{{typeList}}" bindchange="onTypeChange" value="{{typeIndex}}" disabled="{{!categoryList.length}}">
      <view class="picker-text">{{typeList[typeIndex] || '请先选择宠物大类'}}</view>
    </picker>
  </view>

  <view class="form-item">
    <text class="label">宠物品种</text>
    <picker mode="selector" range="{{breedList}}" bindchange="onBreedChange" value="{{breedIndex}}" disabled="{{!typeList.length}}">
      <view class="picker-text">{{breedList[breedIndex] || '请先选择宠物小类'}}</view>
    </picker>
  </view>

  <button class="submit-btn" bindtap="onSubmit">完成注册</button>
</view>