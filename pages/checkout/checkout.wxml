<view class="container">
  <!-- 地址信息 -->
  <view class="address-section" catchtap="selectAddress">
    <view wx:if="{{address}}" class="address-info">
      <view class="address-header">
        <text class="address-name">{{address.name}}</text>
        <text class="address-phone">{{address.phone}}</text>
      </view>
      <view class="address-detail">{{address.province}}{{address.city}}{{address.district}}{{address.detail}}</view>
      <text class="address-arrow">></text>
    </view>
    <view wx:else class="no-address">
      <text class="no-address-text">请选择收货地址</text>
      <text class="address-arrow">></text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="products-section">
    <view class="section-title">商品信息</view>
    <view class="order-products">
      <view wx:for="{{selectedItems}}" wx:key="cartItemId" class="order-product-item">
        <image src="{{item.image}}" mode="aspectFill" class="product-image" />
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-spec" wx:if="{{item.spec}}">规格：{{item.spec}}</view>
          <view class="product-footer">
            <text class="product-price">¥{{item.price}}</text>
            <text class="product-quantity">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 优惠信息 -->
  <view class="coupon-section">
    <view class="coupon-row">
      <text class="coupon-label">优惠券</text>
      <text class="coupon-value" catchtap="selectCoupon">-¥{{discountAmount}} ></text>
    </view>
    <view class="coupon-row">
      <text class="coupon-label">积分抵扣</text>
      <view class="points-switch">
        <checkbox checked="{{usePoints}}" bindtap="togglePoints" />
        <text class="points-text">使用{{availablePoints}}积分</text>
      </view>
    </view>
  </view>

  <!-- 费用明细 -->
  <view class="fee-section">
    <view class="fee-row">
      <text class="fee-label">商品总额</text>
      <text class="fee-value">¥{{totalAmount}}</text>
    </view>
    <view class="fee-row">
      <text class="fee-label">运费</text>
      <text class="fee-value">¥{{shippingFee}}</text>
    </view>
    <view class="fee-row" wx:if="{{discountAmount > 0}}">
      <text class="fee-label">优惠</text>
      <text class="fee-value discount">-¥{{discountAmount}}</text>
    </view>
    <view class="fee-row" wx:if="{{usePoints}}">
      <text class="fee-label">积分抵扣</text>
      <text class="fee-value discount">-¥{{pointsDiscount}}</text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="remark-section">
    <text class="remark-label">订单备注</text>
    <textarea class="remark-input" placeholder="选填，请输入备注信息" bindinput="onRemarkInput" value="{{remark}}" maxlength="200" />
  </view>

  <!-- 支付方式 -->
  <view class="payment-section">
    <view class="section-title">支付方式</view>
    <view class="payment-methods">
      <view class="payment-item {{paymentMethod === 'wechat' ? 'active' : ''}}" catchtap="selectPayment" data-method="wechat">
        <view class="payment-left">
          <text class="payment-icon">💚</text>
          <text class="payment-name">微信支付</text>
        </view>
        <text class="payment-check" wx:if="{{paymentMethod === 'wechat'}}">✓</text>
      </view>
      <view class="payment-item {{paymentMethod === 'balance' ? 'active' : ''}}" catchtap="selectPayment" data-method="balance">
        <view class="payment-left">
          <text class="payment-icon">💰</text>
          <text class="payment-name">余额支付</text>
        </view>
        <text class="payment-check" wx:if="{{paymentMethod === 'balance'}}">✓</text>
      </view>
    </view>
  </view>
</view>

<!-- 底部提交栏 -->
<view class="submit-bar">
  <view class="submit-left">
    <view class="total-price">
      <text class="price-label">应付：</text>
      <text class="price-value">¥{{finalAmount}}</text>
    </view>
  </view>
  <button class="submit-btn" bindtap="submitOrder">提交订单</button>
</view>
