<view class="help-page" style="padding-top: {{statusBarTop + 20}}rpx; padding-bottom: {{safeBottom + 20}}rpx;">
  <!-- 常见问题列表 -->
  <view class="faq-card">
    <view class="faq-item {{expandedId === item.id ? 'expanded' : ''}}" 
          wx:for="{{faqList}}" 
          wx:key="id"
          bindtap="toggleExpand"
          data-id="{{item.id}}">
      <view class="faq-question">
        <text class="question-icon">Q</text>
        <text class="question-text">{{item.question}}</text>
        <text class="expand-icon {{expandedId === item.id ? 'rotated' : ''}}">▼</text>
      </view>
      <view class="faq-answer" wx:if="{{expandedId === item.id}}">
        <text class="answer-text">{{item.answer}}</text>
      </view>
    </view>
  </view>

  <!-- 联系客服 -->
  <view class="service-card">
    <view class="service-header">
      <text class="service-title">没找到答案？</text>
    </view>
    <view class="service-content">
      <view class="service-btn" bindtap="contactService" hover-class="tap-hover">
        <text class="service-icon">📞</text>
        <text class="service-text">联系人工客服</text>
      </view>
    </view>
  </view>
</view>
