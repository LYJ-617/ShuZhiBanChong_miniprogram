<view class="container">
  <view class="setting-list">
    <view class="setting-group">
      <view class="setting-item" bindtap="goToProfile">
        <text class="setting-label">个人资料</text>
        <text class="setting-desc">头像、用户名、手机号、地址</text>
        <text class="arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToAccount">
        <text class="setting-label">账号与安全</text>
        <text class="setting-desc">密码、手机号</text>
        <text class="arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToPrivacy">
        <text class="setting-label">隐私</text>
        <text class="setting-desc">个人信息、权限</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="setting-group">
      <view class="setting-item" bindtap="goToNotification">
        <text class="setting-label">新消息通知</text>
        <text class="arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToGeneral">
        <text class="setting-label">通用</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="setting-group">
      <view class="setting-item" bindtap="clearCache">
        <text class="setting-label">清除缓存</text>
        <text class="cache-size">{{cacheSize}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToAbout">
        <text class="setting-label">关于</text>
        <text class="setting-desc">当前版本 1.0.0</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="setting-group">
      <view class="setting-item logout-item" bindtap="logout">
        <text class="setting-label logout-text">退出登录</text>
      </view>
    </view>
  </view>
</view>
