<view class="container" style="padding-top: {{statusBarTop + 20}}rpx; padding-bottom: {{safeBottom + 120}}rpx;">
  <view class="pet-selector">
    <view wx:for="{{petList}}" wx:key="id" class="pet-tag {{selectedPetId === item.id ? 'active' : ''}}" bindtap="selectPet" data-pet-id="{{item.id}}">{{item.petName}}</view>
  </view>

  <view class="panel pet-info" wx:if="{{selectedPet}}">
    <view>{{selectedPet.petName}} · {{selectedPet.type}} · {{selectedPet.breed}}</view>
    <view>性别：{{selectedPet.gender}}  年龄：{{petAgeText}}</view>
  </view>

  <view class="panel" wx:if="{{report}}">
    <view class="title">日志关键词</view>
    <view class="keyword-wrap">
      <text wx:for="{{keywords}}" wx:key="*this" class="keyword">{{item}}</text>
    </view>
  </view>

  <view class="panel risk risk-{{report.riskLevel}}" wx:if="{{report}}">
    <view class="title">风险评估 · {{riskText}}</view>
    <view class="desc">{{riskDesc}}</view>
  </view>

  <view class="panel" wx:if="{{report}}">
    <view class="title">高概率病症</view>
    <view class="line" wx:for="{{diseaseRank}}" wx:key="name">
      <text>{{item.name}}（{{item.prob}}）</text>
      <text class="muted">{{item.symptom}}</text>
    </view>
  </view>

  <view class="panel" wx:if="{{report}}">
    <view class="title">智能推荐</view>
    <view class="line" wx:for="{{report.recommendProducts}}" wx:key="*this" bindtap="goService" data-type="mall">{{item}}</view>
    <view class="line" wx:for="{{report.recommendDoctors}}" wx:key="*this" bindtap="goService" data-type="consult">{{item}}</view>
    <view class="line" wx:for="{{report.recommendHospitals}}" wx:key="*this" bindtap="goService" data-type="reserve">{{item}}</view>
  </view>

  <view class="panel">
    <view class="title">历史报告</view>
    <view class="line" wx:for="{{history}}" wx:key="id" bindtap="openHistory" data-id="{{item.id}}">
      <text>{{item.date}} · {{item.petName}} · {{item.riskText}}</text>
    </view>
  </view>

  <view class="actions">
    <button class="btn" bindtap="generateReport" disabled="{{!selectedPetId}}">生成报告</button>
    <button class="btn ghost" bindtap="shareReport" disabled="{{!report}}">分享</button>
    <button class="btn ghost" bindtap="printReport" disabled="{{!report}}">打印(A4)</button>
  </view>

  <view class="disclaimer">免责声明：本报告仅用于健康管理参考，不可替代专业兽医诊断。</view>
</view>