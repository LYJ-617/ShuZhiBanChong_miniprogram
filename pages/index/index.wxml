<!-- pages/index/index.wxml -->
<view class="index-container">
  <!-- 顶部渐变背景区 -->
  <view class="top-gradient-bg">
    <!-- 用户信息 -->
    <view class="user-info-bar">
      <text class="greeting">你好，{{username || '主人'}}</text>
      <text class="subtitle">欢迎来到数智伴宠</text>
    </view>
  </view>

  <!-- 1. 日程提醒区 -->
  <view class="schedule-section">
    <view class="section-header">
      <text class="section-title">今日提醒</text>
      <text class="more-btn" bindtap="goToScheduleAll">查看全部</text>
    </view>

    <!-- 提醒卡片横向滚动 -->
    <scroll-view class="schedule-scroll" scroll-x="true" show-scrollbar="false">
      <view class="schedule-list">
        <view class="schedule-card" wx:for="{{scheduleList}}" wx:key="id" bindtap="openScheduleDetail" data-item="{{item}}">
          <view class="schedule-icon" style="background-color: {{item.iconBg}};">
            <text class="icon-text">{{index === 0 ? '💉' : index === 1 ? '🐛' : '🛁'}}</text>
          </view>
          <view class="schedule-content">
            <text class="schedule-title">{{item.title}}</text>
            <text class="schedule-time">{{item.time}}</text>
          </view>
          <view class="schedule-status {{item.isDone ? 'done' : 'pending'}}">
            {{item.isDone ? '已完成' : '待完成'}}
          </view>
        </view>
      </view>
      <!-- 无提醒时的空状态 -->
      <view class="schedule-empty" wx:if="{{scheduleList.length === 0}}">
        <text class="empty-text">今日暂无待办提醒~</text>
      </view>
    </scroll-view>
  </view>

  <!-- 2. 功能图标入口区 -->
  <view class="function-section">
    <view class="function-grid">
      <view class="function-item" bindtap="switchTab" data-url="/pages/log/log">
        <view class="function-icon" style="background: linear-gradient(135deg, #52c41a, #73d13d);">
          <text class="icon-text">📝</text>
        </view>
        <text class="function-name">记录</text>
      </view>
      <view class="function-item" bindtap="switchTab" data-url="/pages/community/community">
        <view class="function-icon" style="background: linear-gradient(135deg, #4FC3F7, #2196F3);">
          <text class="icon-text">🏠</text>
        </view>
        <text class="function-name">社区</text>
      </view>
      <view class="function-item" bindtap="switchTab" data-url="/pages/service/service">
        <view class="function-icon" style="background: linear-gradient(135deg, #81C784, #4CAF50);">
          <text class="icon-text">🛒</text>
        </view>
        <text class="function-name">服务</text>
      </view>
      <view class="function-item" bindtap="switchTab" data-url="/pages/mine/mine">
        <view class="function-icon" style="background: linear-gradient(135deg, #BA68C8, #9C27B0);">
          <text class="icon-text">👤</text>
        </view>
        <text class="function-name">我的</text>
      </view>
    </view>
  </view>

  <!-- 3. 日志状态提示区 -->
  <view class="log-tip-section">
    <!-- 无日志时显示提示 -->
    <view class="no-log-tip" wx:if="{{!hasTodayLog && petList.length > 0}}">
      <text class="tip-icon-emoji">🐾</text>
      <text class="tip-text">今天还没有记录毛孩子的状态哦~</text>
      <button class="tip-btn" bindtap="goToWriteLog">立即记录</button>
    </view>

    <!-- 无宠物时显示提示 -->
    <view class="no-log-tip" wx:if="{{petList.length === 0}}">
      <text class="tip-icon-emoji">🐶</text>
      <text class="tip-text">还没有添加宠物哦</text>
      <button class="tip-btn" bindtap="goToRegister">添加宠物</button>
    </view>

    <!-- 有日志时显示今日日志卡片 -->
    <view class="today-log-card" wx:if="{{hasTodayLog && todayLog}}">
      <view class="log-card-header">
        <text class="log-card-title">今日养宠日志</text>
        <text class="log-card-time">{{todayLog.createTime}}</text>
      </view>
      <view class="log-card-content">{{todayLog.content}}</view>
      <view class="log-card-footer">
        <text class="log-tag" wx:for="{{todayLog.tags}}" wx:key="index">#{{item}}</text>
        <text class="view-detail" bindtap="goToLogDetail">查看详情</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区占位 -->
  <view class="safe-bottom"></view>
</view>