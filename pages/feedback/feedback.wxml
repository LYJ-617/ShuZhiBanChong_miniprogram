<view class="feedback-page {{nightMode ? 'night-mode' : ''}}" style="padding-top: {{statusBarTop + 20}}rpx; padding-bottom: {{safeBottom + 20}}rpx;">
  
  <!-- 提示卡片 -->
  <view class="tip-card">
    <view class="tip-icon">💡</view>
    <view class="tip-content">
      <text class="tip-title">反馈建议</text>
      <text class="tip-desc">我们非常重视您的反馈，欢迎提出宝贵的意见和建议，帮助我们做得更好。</text>
    </view>
  </view>

  <!-- 反馈类型选择 -->
  <view class="type-card">
    <view class="card-header">
      <text class="card-title">问题类型</text>
      <text class="required-mark">*</text>
    </view>
    <view class="type-grid">
      <view 
        wx:for="{{feedbackTypes}}" 
        wx:key="id" 
        class="type-item {{selectedType === item.id ? 'selected' : ''}}"
        bindtap="selectType"
        data-type="{{item.id}}"
      >
        <text class="type-icon">{{item.icon}}</text>
        <text class="type-label">{{item.label}}</text>
        <view class="type-check" wx:if="{{selectedType === item.id}}">✓</view>
      </view>
    </view>
  </view>

  <!-- 反馈内容 -->
  <view class="content-card">
    <view class="card-header">
      <text class="card-title">详细描述</text>
      <text class="required-mark">*</text>
      <text class="word-count">{{contentLength}}/500</text>
    </view>
    <textarea 
      class="feedback-textarea"
      placeholder="请详细描述您遇到的问题或建议...\n\n建议格式：\n• 问题描述：\n• 期望效果：\n• 复现步骤：（如有）"
      placeholder-class="textarea-placeholder"
      maxlength="500"
      bindinput="onContentInput"
      value="{{content}}"
    />
  </view>

  <!-- 图片上传 -->
  <view class="image-card">
    <view class="card-header">
      <text class="card-title">上传截图</text>
      <text class="card-hint">（选填，最多4张）</text>
    </view>
    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image class="uploaded-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}"/>
        <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">✕</view>
      </view>
      <view class="image-add" bindtap="chooseImage" wx:if="{{images.length < 4}}">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-card">
    <view class="card-header">
      <text class="card-title">联系方式</text>
      <text class="card-hint">（选填，方便我们联系您）</text>
    </view>
    <view class="contact-tabs">
      <view class="contact-tab {{contactType === 'phone' ? 'active' : ''}}" bindtap="selectContactType" data-type="phone">
        <text class="tab-icon">📱</text>
        <text class="tab-label">手机号</text>
      </view>
      <view class="contact-tab {{contactType === 'email' ? 'active' : ''}}" bindtap="selectContactType" data-type="email">
        <text class="tab-icon">✉️</text>
        <text class="tab-label">邮箱</text>
      </view>
    </view>
    <input 
      wx:if="{{contactType === 'phone'}}"
      class="contact-input"
      type="number"
      placeholder="请输入手机号"
      placeholder-class="input-placeholder"
      bindinput="onContactInput"
      value="{{contact}}"
      maxlength="11"
    />
    <input 
      wx:else
      class="contact-input"
      type="text"
      placeholder="请输入邮箱地址"
      placeholder-class="input-placeholder"
      bindinput="onContactInput"
      value="{{contact}}"
    />
  </view>

  <!-- 设备信息 -->
  <view class="device-card">
    <view class="card-header">
      <text class="card-title">设备信息</text>
      <text class="card-hint">（自动收集）</text>
    </view>
    <view class="device-info">
      <view class="device-item">
        <text class="device-label">应用版本</text>
        <text class="device-value">{{deviceInfo.version}}</text>
      </view>
      <view class="device-item">
        <text class="device-label">系统版本</text>
        <text class="device-value">{{deviceInfo.system}}</text>
      </view>
      <view class="device-item">
        <text class="device-label">设备型号</text>
        <text class="device-value">{{deviceInfo.model}}</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitFeedback">
      <text class="submit-text">{{submitting ? '提交中...' : '提交反馈'}}</text>
      <view class="submit-loading" wx:if="{{submitting}}"></view>
    </view>
  </view>

  <!-- 历史反馈入口 -->
  <view class="history-section" bindtap="goToHistory">
    <view class="history-icon">📋</view>
    <view class="history-content">
      <text class="history-title">我的反馈</text>
      <text class="history-desc">查看反馈处理进度</text>
    </view>
    <text class="history-arrow">›</text>
  </view>

  <!-- 常见问题快捷入口 -->
  <view class="faq-section">
    <view class="faq-card">
      <view class="faq-header" bindtap="goToFAQ">
        <text class="faq-title">常见问题</text>
        <text class="faq-more">查看更多 ›</text>
      </view>
      <view class="faq-list">
        <view class="faq-item" bindtap="goToFAQDetail" data-id="1">
          <text class="faq-q">Q: 如何添加宠物？</text>
        </view>
        <view class="faq-item" bindtap="goToFAQDetail" data-id="2">
          <text class="faq-q">Q: 如何记录宠物健康？</text>
        </view>
        <view class="faq-item" bindtap="goToFAQDetail" data-id="3">
          <text class="faq-q">Q: 数据同步失败怎么办？</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 客服热线 -->
  <view class="service-section">
    <text class="service-label">遇到紧急问题？</text>
    <view class="service-btn" bindtap="callService">
      <text class="service-icon">📞</text>
      <text class="service-phone">400-xxx-xxxx</text>
    </view>
  </view>

  <!-- 底部安全间距 -->
  <view class="safe-area-bottom"></view>
</view>

<!-- 提交成功弹窗 -->
<view wx:if="{{showSuccessModal}}" class="modal-mask" bindtap="closeSuccessModal">
  <view class="modal-content success-modal" catchtap="preventBubble">
    <view class="success-icon-wrap">
      <text class="success-icon">✓</text>
    </view>
    <text class="success-title">提交成功</text>
    <text class="success-desc">感谢您的反馈，我们会尽快处理！</text>
    <view class="success-ticket">
      <text class="ticket-label">反馈单号</text>
      <text class="ticket-number">{{ticketNumber}}</text>
    </view>
    <view class="success-actions">
      <view class="action-btn secondary" bindtap="closeSuccessModal">
        <text>返回</text>
      </view>
      <view class="action-btn primary" bindtap="goToHistory">
        <text>查看进度</text>
      </view>
    </view>
  </view>
</view>

<!-- Loading遮罩 -->
<view wx:if="{{showLoading}}" class="loading-mask">
  <view class="loading-content">
    <view class="loading-spinner"></view>
    <text class="loading-text">{{loadingText}}</text>
  </view>
</view>

<!-- Toast提示 -->
<view wx:if="{{showToast}}" class="toast-mask">
  <view class="toast-content">
    <text class="toast-icon">{{toastSuccess ? '✓' : '✗'}}</text>
    <text class="toast-text">{{toastMessage}}</text>
  </view>
</view>
