<view class="community-page" style="padding-bottom: {{safeBottom + 140}}rpx;">
  <view class="top-gradient">
    <view class="status-placeholder" style="height: {{statusBarTop}}rpx;"></view>
    <view class="search-bar" style="height: 78rpx; display: flex; box-sizing: border-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索" placeholder-class="search-placeholder" bindinput="onSearchInput" />
      </view>
  </view>

  <view class="tab-container">
    <view class="tab-row">
      <view wx:for="{{tabs}}" wx:key="*this" class="tab-item {{selectedTag === item ? 'active' : ''}}" bindtap="selectTag" data-tag="{{item}}">
        <text class="tab-text">{{item}}</text>
        <view class="tab-indicator"></view>
      </view>
    </view>
    <view class="tab-slider" style="{{tabSliderStyle}}"></view>
  </view>

  <view class="waterfall">
    <view class="column">
      <view wx:for="{{leftPosts}}" wx:key="id" class="card" hover-class="tap-hover" bindtap="onPostTap" data-post-id="{{item.id}}" bindtouchstart="onCardTouchStart" data-index="{{index}}" data-column="left">
        <view wx:if="{{userInfo && userInfo.id === item.userId}}" class="more-icon" catchtap="showPostActionSheet" data-post-id="{{item.id}}">•••</view>
        <view class="image-wrap" wx:if="{{item.images && item.images.length}}">
          <image 
            class="cover" 
            src="{{item.images[0]}}" 
            mode="widthFix" 
            lazy-load="true" 
            catchtap="previewImage" 
            data-post-id="{{item.id}}" 
            data-image="{{item.images[0]}}"
            binderror="onImageError"
            data-error-index="0"
          ></image>
          <!-- 多图指示器 -->
          <view class="image-count" wx:if="{{item.images.length > 1}}">
            <text class="image-count-text">{{item.images.length}}张</text>
          </view>
          <view wx:if="{{likedPostId === item.id && likeAnimating}}" class="like-anim">❤</view>
        </view>
        <view class="card-content">
          <view class="title">{{item.content}}</view>
          <view class="footer">
            <image class="avatar" src="{{item.userAvatar || '/static/images/default-avatar.png'}}" mode="aspectFill"></image>
            <text class="name">{{item.username}}</text>
            <view class="like-wrapper" catchtap="toggleLike" data-post-id="{{item.id}}">
              <text class="like-icon {{userLikes[item.id] ? 'liked' : ''}}">❤</text>
              <text class="like-count {{userLikes[item.id] ? 'liked' : ''}}">{{item.likeCount}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="column">
      <view wx:for="{{rightPosts}}" wx:key="id" class="card" hover-class="tap-hover" bindtap="onPostTap" data-post-id="{{item.id}}" bindtouchstart="onCardTouchStart" data-index="{{index}}" data-column="right">
        <view wx:if="{{userInfo && userInfo.id === item.userId}}" class="more-icon" catchtap="showPostActionSheet" data-post-id="{{item.id}}">•••</view>
        <view class="image-wrap" wx:if="{{item.images && item.images.length}}">
          <image 
            class="cover" 
            src="{{item.images[0]}}" 
            mode="widthFix" 
            lazy-load="true" 
            catchtap="previewImage" 
            data-post-id="{{item.id}}" 
            data-image="{{item.images[0]}}"
            binderror="onImageError"
            data-error-index="0"
          ></image>
          <!-- 多图指示器 -->
          <view class="image-count" wx:if="{{item.images.length > 1}}">
            <text class="image-count-text">{{item.images.length}}张</text>
          </view>
          <view wx:if="{{likedPostId === item.id && likeAnimating}}" class="like-anim">❤</view>
        </view>
        <view class="card-content">
          <view class="title">{{item.content}}</view>
          <view class="footer">
            <image class="avatar" src="{{item.userAvatar || '/static/images/default-avatar.png'}}" mode="aspectFill"></image>
            <text class="name">{{item.username}}</text>
            <view class="like-wrapper" catchtap="toggleLike" data-post-id="{{item.id}}">
              <text class="like-icon {{userLikes[item.id] ? 'liked' : ''}}">❤</text>
              <text class="like-count {{userLikes[item.id] ? 'liked' : ''}}">{{item.likeCount}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <loading-state show="{{loading}}" text="加载中..." />
  <empty-state wx:if="{{!loading && leftPosts.length===0 && rightPosts.length===0}}" text="暂无内容哦～" btnText="去记录" bind:action="showPublishModal" />
  <view class="loading-text" wx:if="{{!loading && !hasMore}}">没有更多了</view>

  <!-- P1优先级：添加wx:if控制，当评论弹窗打开时隐藏FAB按钮 -->
  <view class="fab {{fabVisible ? '' : 'hidden'}}" style="{{fabBottomStyle}}" hover-class="tap-hover" bindtap="showPublishModal">
    <text class="fab-plus">+</text>
  </view>

  <view wx:if="{{publishModalVisible}}" class="modal-mask" bindtap="hidePublishModal">
    <view class="publish-modal" catchtap="noop">
      <view class="modal-title">发布帖子</view>
      <view class="publish-scroll">
        <community-publish class="publish-component" bind:postData="onPostDataChange" />
      </view>
      <view class="publish-actions">
        <button class="action-btn ghost" bindtap="hidePublishModal">取消</button>
        <button class="action-btn" bindtap="submitPost">发布</button>
      </view>
    </view>
  </view>

  <!-- P1优先级：评论弹窗层级提升，z-index:10000 -->
  <view wx:if="{{commentVisible}}" class="comment-mask" style="z-index: 9999;" bindtap="closeComments">
    <view class="comment-panel" style="z-index: 10000;" catchtap="noop">
      <view class="comment-head">
        <text class="close-btn" bindtap="closeComments">✕</text>
        <text class="comment-title">评论</text>
        <view></view>
      </view>
      <scroll-view scroll-y class="comment-list" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view wx:if="{{!currentPost.comments || !currentPost.comments.length}}" class="empty-comment">
          还没有评论，快来抢沙发吧～
        </view>
        <view class="comment-item {{item.userId === userInfo.id ? 'own-comment' : ''}}" wx:for="{{currentPost.comments}}" wx:key="id" bindlongpress="onCommentLongPress" data-comment-id="{{item.id}}">
          <view class="comment-user-row">
            <image class="comment-avatar" src="{{item.userAvatar || '/static/images/default-avatar.png'}}" mode="aspectFill"></image>
            <text class="comment-username">{{item.username}}</text>
            <text class="comment-time">{{formatTime(item.createTime)}}</text>
          </view>
          <view class="comment-content">{{item.content}}</view>
          <view class="comment-actions">
            <view class="comment-like" catchtap="likeComment" data-post-id="{{currentPost.id}}" data-comment-id="{{item.id}}">
              <text class="comment-like-icon">❤</text>
              <text class="comment-like-count">{{item.likeCount}}</text>
            </view>
            <view class="comment-edit-actions" wx:if="{{item.userId === userInfo.id}}">
              <text class="comment-edit" catchtap="onCommentLongPress" data-comment-id="{{item.id}}">编辑</text>
              <text class="comment-delete" catchtap="deleteComment" data-comment-id="{{item.id}}">删除</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="comment-input-row">
        <input class="comment-input {{isEditingComment ? 'editing' : ''}}" value="{{commentInput}}" bindinput="onCommentInput" placeholder="{{isEditingComment ? '编辑评论...' : '发表友善评论...'}}" placeholder-class="comment-input-placeholder" maxlength="300" focus="{{isEditingComment}}" />
        <button class="send-btn {{commentInput ? '' : 'disabled'}}" bindtap="submitComment">{{isEditingComment ? '保存' : '发送'}}</button>
      </view>
    </view>
  </view>
</view>