<view class="container">
  <view class="form-item">
    <text class="label">帖子内容</text>
    <textarea class="textarea" placeholder="请输入帖子内容" bindinput="onContentInput" value="{{content}}" />
  </view>
  <view class="form-item">
    <text class="label">话题标签</text>
    <view class="tag-list">
      <view class="tag {{tags.includes('日常记录') ? 'active' : ''}}" bindtap="toggleTag" data-tag="日常记录">日常记录</view>
      <view class="tag {{tags.includes('医疗知识') ? 'active' : ''}}" bindtap="toggleTag" data-tag="医疗知识">医疗知识</view>
      <view class="tag {{tags.includes('好物分享') ? 'active' : ''}}" bindtap="toggleTag" data-tag="好物分享">好物分享</view>
      <view class="tag {{tags.includes('科普知识') ? 'active' : ''}}" bindtap="toggleTag" data-tag="科普知识">科普知识</view>
    </view>
  </view>
</view>