<view class="container">
  <view class="form-item">
    <text class="label">选择宠物</text>
    <view class="tag-list">
      <view wx:for="{{petList}}" wx:key="id" class="tag {{selectedPetId === item.id ? 'active' : ''}}" bindtap="selectPet" data-pet-id="{{item.id}}">{{item.petName}}</view>
    </view>
  </view>
  <view class="form-item">
    <text class="label">日志内容</text>
    <textarea class="textarea" placeholder="请输入日志内容" bindinput="onContentInput" value="{{content}}" />
  </view>
  <view class="form-item">
    <text class="label">参与话题</text>
    <view class="tag-list">
      <view class="tag {{tags.includes('日常') ? 'active' : ''}}" bindtap="toggleTag" data-tag="日常">日常</view>
      <view class="tag {{tags.includes('科普') ? 'active' : ''}}" bindtap="toggleTag" data-tag="科普">科普</view>
      <view class="tag {{tags.includes('健康') ? 'active' : ''}}" bindtap="toggleTag" data-tag="健康">健康</view>
      <view class="tag {{tags.includes('趣事') ? 'active' : ''}}" bindtap="toggleTag" data-tag="趣事">趣事</view>
    </view>
  </view>
  <view class="form-item">
    <text class="label">发布位置</text>
    <view class="tag-list">
      <view class="tag {{publishTo.includes('petLog') ? 'active' : ''}}" bindtap="togglePublishTo" data-to="petLog">宠物日志</view>
      <view class="tag {{publishTo.includes('community') ? 'active' : ''}}" bindtap="togglePublishTo" data-to="community">社区</view>
    </view>
  </view>
  <view class="form-item" wx:if="{{tags.includes('健康')}}">
    <text class="label">健康状态（选填）</text>
    <view class="health-item">
      <text class="sub-label">粪便情况：</text>
      <view class="tag-list">
        <view class="tag {{healthInfo.stool === '正常' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="stool" data-value="正常">正常</view>
        <view class="tag {{healthInfo.stool === '稀软' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="stool" data-value="稀软">稀软</view>
        <view class="tag {{healthInfo.stool === '干结' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="stool" data-value="干结">干结</view>
      </view>
    </view>
    <view class="health-item">
      <text class="sub-label">食欲情况：</text>
      <view class="tag-list">
        <view class="tag {{healthInfo.appetite === '正常' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="appetite" data-value="正常">正常</view>
        <view class="tag {{healthInfo.appetite === '不佳' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="appetite" data-value="不佳">不佳</view>
        <view class="tag {{healthInfo.appetite === '旺盛' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="appetite" data-value="旺盛">旺盛</view>
      </view>
    </view>
    <view class="health-item">
      <text class="sub-label">精神状态：</text>
      <view class="tag-list">
        <view class="tag {{healthInfo.spirit === '正常' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="spirit" data-value="正常">正常</view>
        <view class="tag {{healthInfo.spirit === '不佳' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="spirit" data-value="不佳">不佳</view>
        <view class="tag {{healthInfo.spirit === '亢奋' ? 'active' : ''}}" bindtap="selectHealthInfo" data-key="spirit" data-value="亢奋">亢奋</view>
      </view>
    </view>
  </view>
</view>