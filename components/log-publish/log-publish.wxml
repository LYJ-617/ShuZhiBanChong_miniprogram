<view class="container">
  <view class="form-item">
    <text class="label">选择宠物</text>
    <view class="input-wrapper" catchtap="showPetPicker">
      <text class="input-text {{!selectedPetName ? 'placeholder' : ''}}">{{selectedPetName || '请选择宠物'}}</text>
      <text class="arrow">›</text>
    </view>
  </view>
  <view class="form-item">
    <text class="label">日志内容</text>
    <textarea class="textarea" placeholder="请输入日志内容" bindinput="onContentInput" value="{{content}}" catchtap="doNothing" />
  </view>
  <view class="form-item">
    <text class="label">参与话题</text>
    <view class="input-wrapper">
      <input class="input-text" placeholder="请输入话题（如：#日常）" bindinput="onTopicInput" value="{{topicInput}}" catchtap="doNothing" />
    </view>
  </view>
  <view class="form-item">
    <text class="label">我的位置（选填）</text>
    <view class="input-wrapper" catchtap="selectLocation">
      <text class="input-text {{!location ? 'placeholder' : ''}}">{{location || '点击获取当前位置'}}</text>
      <text class="arrow">›</text>
    </view>
  </view>
  <view class="form-item" wx:if="{{tags.includes('健康')}}">
    <text class="label">健康状态（选填）</text>
    <view class="health-item">
      <text class="sub-label">粪便情况：</text>
      <view class="tag-list">
        <view class="tag {{healthInfo.stool === '正常' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="stool" data-value="正常">正常</view>
        <view class="tag {{healthInfo.stool === '稀软' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="stool" data-value="稀软">稀软</view>
        <view class="tag {{healthInfo.stool === '干结' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="stool" data-value="干结">干结</view>
      </view>
    </view>
    <view class="health-item">
      <text class="sub-label">食欲情况：</text>
      <view class="tag-list">
        <view class="tag {{healthInfo.appetite === '正常' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="appetite" data-value="正常">正常</view>
        <view class="tag {{healthInfo.appetite === '不佳' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="appetite" data-value="不佳">不佳</view>
        <view class="tag {{healthInfo.appetite === '旺盛' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="appetite" data-value="旺盛">旺盛</view>
      </view>
    </view>
    <view class="health-item">
      <text class="sub-label">精神状态：</text>
      <view class="tag-list">
        <view class="tag {{healthInfo.spirit === '正常' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="spirit" data-value="正常">正常</view>
        <view class="tag {{healthInfo.spirit === '不佳' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="spirit" data-value="不佳">不佳</view>
        <view class="tag {{healthInfo.spirit === '亢奋' ? 'active' : ''}}" catchtap="selectHealthInfo" data-key="spirit" data-value="亢奋">亢奋</view>
      </view>
    </view>
  </view>

  <!-- 宠物选择器 -->
  <view wx:if="{{showPetPickerFlag}}" class="picker-popup" catchtap="hidePetPicker">
    <view class="picker-content" catchtap="doNothing">
      <view class="picker-header">
        <text class="picker-title">选择宠物</text>
        <text class="picker-close" catchtap="hidePetPicker">✕</text>
      </view>
      <scroll-view class="picker-scroll" scroll-y>
        <view wx:for="{{petList}}" wx:key="id" class="picker-item {{selectedPetId === item.id ? 'selected' : ''}}" catchtap="selectPetFromPicker" data-pet-id="{{item.id}}">
          <text class="picker-text">{{item.petName}}</text>
          <text wx:if="{{selectedPetId === item.id}}" class="picker-check">✓</text>
        </view>
        <view wx:if="{{petList.length === 0}}" class="picker-empty">
          <text class="empty-text">暂无宠物，请先添加宠物</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>