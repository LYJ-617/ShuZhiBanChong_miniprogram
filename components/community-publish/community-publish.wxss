.container {
  padding: 32rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: block;
  color: #333;
}

/* 标签模块容器 */
.tag-section {
  margin: 20rpx 0;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

/* 标签标题 */
.tag-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

/* 标签容器 */
.tag-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 未选中态 默认灰色样式 */
.tag-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #F0F0F0;
  color: #333333;
  font-size: 26rpx;
  font-weight: 400;
  border: none;
  border-radius: 32rpx;
  padding: 16rpx 32rpx;
  transition: all 0.2s ease-in-out;
}

/* 点击反馈效果 */
.tag-item:active {
  transform: scale(0.98);
}

/* 选中态 点击后绿色样式 */
.tag-item.active {
  background-color: #4CAF50;
  color: #FFFFFF;
}

.textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 32rpx;
  background-color: #f9f9f9;
  border: 2rpx solid #e5e5e5;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  box-sizing: border-box;
  text-align: left;
  vertical-align: top;
}

.textarea:focus {
  border-color: #52c41a;
  background-color: #fff;
}

/* 图片上传区域样式 */
.image-upload-area {
  margin-top: 16rpx;
}

.empty-upload {
  height: 150rpx;
  border: 1rpx dashed #f0f0f0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fafafa;
  transition: all 0.2s ease;
}

.empty-upload:active {
  background: #f0f0f0;
  border-color: #52c41a;
}

.upload-icon {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
}

.image-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.image-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  overflow: hidden;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.image-item.dragging {
  opacity: 0.7;
  transform: scale(1.05);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.3);
  z-index: 10;
}

.image-item.drop-target {
  transform: scale(0.95);
  opacity: 0.6;
}

.preview-img {
  width: 100%;
  height: 100%;
}

/* 编辑按钮 */
.edit-btn {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 12rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 20rpx;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.edit-btn:active {
  background: rgba(0, 0, 0, 0.7);
}

.image-item:active .edit-btn,
.image-item:hover .edit-btn {
  opacity: 1;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.delete-btn:active {
  background: rgba(0, 0, 0, 0.7);
  transform: scale(1.1);
}

/* 拖拽提示 */
.drag-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(82, 196, 26, 0.9);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 6rpx 0;
}

/* 拖拽提示文字 */
.drag-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.add-image-btn {
  width: 120rpx;
  height: 120rpx;
  border: 1rpx dashed #ddd;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  transition: all 0.2s ease;
}

.add-image-btn:active {
  background: #f0f0f0;
  border-color: #52c41a;
  border-style: solid;
}

.add-icon {
  font-size: 64rpx;
  color: #ccc;
  line-height: 1;
}
