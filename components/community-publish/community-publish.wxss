.container {
  padding: 16px;
}

.form-item {
  margin-bottom: 24px;
}

.label {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 12px;
  display: block;
  color: #333;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin: 4px -4px;
}

.tag {
  background-color: #f0f0f0;
  border-radius: 20px;
  padding: 8px 16px;
  font-size: 14px;
  margin: 4px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #333;
  border: 1px solid transparent;
  transition: all 0.3s ease;
}

.tag.active {
  background-color: #07c160 !important;
  color: #fff !important;
  border-color: #07c160 !important;
  font-weight: 500 !important;
}

.tag-text {
  margin: 0;
}

.tag-check {
  display: none;
}

.textarea {
  width: 100%;
  min-height: 150px;
  padding: 16px;
  background-color: #f9f9f9;
  border: 2px solid #e5e5e5;
  border-radius: 12px;
  font-size: 16px;
  line-height: 1.6;
  color: #333;
  box-sizing: border-box;
  text-align: left;
  vertical-align: top;
}

.textarea:focus {
  border-color: #576b95;
  background-color: #fff;
}