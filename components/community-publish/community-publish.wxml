<view class="container">
  <view class="form-item">
    <text class="label">帖子内容</text>
    <textarea class="textarea" placeholder="请输入帖子内容" bindinput="onContentInput" value="{{content}}" catchtap="doNothing" />
  </view>
  <view class="form-item">
    <text class="label">话题标签（可多选）</text>
    <view class="tag-list">
      <view class="tag {{tags.includes('日常记录') ? 'active' : ''}}" style="background-color: {{tags.includes('日常记录') ? '#07c160' : '#f0f0f0'}}; color: {{tags.includes('日常记录') ? '#fff' : '#333'}}; border-color: {{tags.includes('日常记录') ? '#07c160' : 'transparent'}};" catchtap="toggleTag" data-tag="日常记录">日常记录</view>
      <view class="tag {{tags.includes('医疗知识') ? 'active' : ''}}" style="background-color: {{tags.includes('医疗知识') ? '#07c160' : '#f0f0f0'}}; color: {{tags.includes('医疗知识') ? '#fff' : '#333'}}; border-color: {{tags.includes('医疗知识') ? '#07c160' : 'transparent'}};" catchtap="toggleTag" data-tag="医疗知识">医疗知识</view>
      <view class="tag {{tags.includes('好物分享') ? 'active' : ''}}" style="background-color: {{tags.includes('好物分享') ? '#07c160' : '#f0f0f0'}}; color: {{tags.includes('好物分享') ? '#fff' : '#333'}}; border-color: {{tags.includes('好物分享') ? '#07c160' : 'transparent'}};" catchtap="toggleTag" data-tag="好物分享">好物分享</view>
      <view class="tag {{tags.includes('科普知识') ? 'active' : ''}}" style="background-color: {{tags.includes('科普知识') ? '#07c160' : '#f0f0f0'}}; color: {{tags.includes('科普知识') ? '#fff' : '#333'}}; border-color: {{tags.includes('科普知识') ? '#07c160' : 'transparent'}};" catchtap="toggleTag" data-tag="科普知识">科普知识</view>
    </view>
  </view>
</view>